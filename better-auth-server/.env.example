# Better Auth server URL (must match Convex issuer and frontend VITE_BETTER_AUTH_URL)
BETTER_AUTH_URL=http://localhost:3000/api/auth

# This branch currently uses the in-memory adapter, so no database URL is needed.

# Generate a strong random value before production use
BETTER_AUTH_SECRET=replace-with-a-strong-secret

# Better Auth Dashboard / Infra key (optional)
BETTER_AUTH_API_KEY=

# Frontend origins allowed to call Better Auth
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:4173

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# HTTP port for this server
PORT=3000
