{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix kanban-board ci",
  "buildCommand": "npm --prefix kanban-board run build",
  "outputDirectory": "kanban-board/dist",
  "functions": {
    "kanban-board/api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/[...handler]"
    }
  ]
}
