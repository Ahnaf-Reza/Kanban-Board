# Set after running `npm run convex:dev`.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Better Auth API base URL. Example: http://localhost:3000/api/auth
VITE_BETTER_AUTH_URL=http://localhost:3000/api/auth

# Comma-separated list of enabled OAuth providers to render in UI.
# Example: google,github
VITE_BETTER_AUTH_OAUTH_PROVIDERS=
