# Set after running `npm run convex:dev`.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Better Auth API base URL. Example: http://localhost:3000/api/auth
VITE_BETTER_AUTH_URL=http://localhost:3000/api/auth

# Better Auth persists auth data in Convex (same as your app data).
# Set BETTER_AUTH_SECRET in the auth server environment.

# Comma-separated list of enabled OAuth providers to render in UI.
# Example: google,github
VITE_BETTER_AUTH_OAUTH_PROVIDERS=

# Cloudinary client-side upload settings (unsigned upload preset).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# Optional folder in your Cloudinary Media Library.
VITE_CLOUDINARY_UPLOAD_FOLDER=kanban-avatars
